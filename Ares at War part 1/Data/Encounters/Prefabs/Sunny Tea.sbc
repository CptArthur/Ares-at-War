                            <Value>[SettingsGasGenerationStatus]

; [ GASPRODUCTION - GENERAL OPTIONS ]
SearchId=*
; Block name filter: Use '*' for all, or text to match block names (case-insensitive substring match)
; Examples: 'Cargo' matches 'Main Cargo', 'Engineering,Medical' matches blocks containing either word

ExcludeIds=Airlock,
; Exclude blocks containing these words (comma-separated, case-insensitive)
; Example: 'Airlock,Backup' excludes blocks with 'Airlock' or 'Backup' in their names

ShowHeader=True
; Display the app title bar at the top of the screen

ShowRatio=False
; Display current/maximum values as numbers instead of percentages

ShowBars=True
; Display visual progress bars for capacity and resource levels

ShowSubgrids=False
; Include blocks from subgrids connected via rotors, pistons, and hinges

SubgridUpdateFrequency=100
; Subgrid scan frequency: 1=fastest (60/sec), 10=normal (6/sec), 100=slowest (0.6/sec)

ShowDocked=False
; Include blocks from grids connected via ship connectors

UseColors=True
; Enable color-coded status indicators (green=good, yellow=warning, red=critical)


; [ GASPRODUCTION - LAYOUT OPTIONS ]
TextSize=0.35
ViewPortOffsetX=10
ViewPortOffsetY=10
TitleFieldWidth=128
RatioFieldWidth=104

; [ GASPRODUCTION - SCREEN OPTIONS ]
ShowHydrogen=True
ShowOxygen=True
ShowIce=True
ShowGenerators=True
ShowOxygenFarms=True
ShowIntakeVent=True

; [ GASPRODUCTION - ITEM THRESHOLDS ]
IceMinAmount=50000

</Value>
                          </item>
                        </dictionary>
                      </Storage>
                    </Component>
