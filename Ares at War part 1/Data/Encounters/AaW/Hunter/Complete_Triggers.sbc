<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <EntityComponents>





    <!--
        [Triggers:AaW_Hunter_Trigger_HasTarget4000]
        [Triggers:AaW_Hunter_Trigger_ApproachingTarget_Player]
	  -->

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AaW_Hunter_Trigger_HasTarget4000</SubtypeId>
      </Id>
      <Description>
        [RivalAI Trigger]

        [Type:HasTarget]

        [Tags:MSB_RoleToCombat_Trigger]

        [UseTrigger:true]
        [StartsReady:true]

        [Conditions:AaW_Hunter_Condition_HasTarget4000]

        [Actions:AaW_Hunter_Action_HasTarget4000]


      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AaW_Hunter_Action_HasTarget4000</SubtypeId>
      </Id>
      <Description>
        [RivalAI Action]
        
        [ManuallyActivateTrigger:true]
        [ManuallyActivatedTriggerTags:MSB_TriggerEvent_InitCombat]
      </Description>
    </EntityComponent>


    
    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AaW_Hunter_Condition_HasTarget4000</SubtypeId>
      </Id>
      <Description>
        [RivalAI Condition]

        [UseConditions:true]
        [MatchAnyCondition:false]

        [HasTarget:true]

        [CheckTargetDistance:true]
        [MaxTargetDistance:4000]
      </Description>
    </EntityComponent>

    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AaW_Hunter_Trigger_ApproachingTarget_Player</SubtypeId>
      </Id>
      <Description>
        [RivalAI Trigger]

        [Type:Manual]

        [Tags:MSB_TriggerEvent_InitialApproachingTarget_Easy]
        [Tags:MSB_TriggerEvent_InitialApproachingTarget_Hard]
        [Tags:MSB_TriggerEvent_InitialApproachingTarget_Other]

        [Conditions:AaW_Hunter_Condition_ApproachingTarget_Player]

        [UseTrigger:true]
        [StartsReady:true]

        [MinCooldownMs:120000]
        [MaxCooldownMs:180000]

        [ActionExecution:Random]
        [Actions:AaW_Hunter_Action_ApproachingTarget_Player]
      </Description>
    </EntityComponent>
    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AaW_Hunter_Condition_ApproachingTarget_Player</SubtypeId>
      </Id>
      <Description>
        [RivalAI Condition]

        [UseConditions:true]
        [MatchAnyCondition:false]

        [CheckIfTargetIsPlayerOwned:true]
        [CheckIfTargetIsNpcOwned:false]
      </Description>
    </EntityComponent>
    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AaW_Hunter_Action_ApproachingTarget_Player</SubtypeId>
      </Id>
      <Description>
        [RivalAI Action]

        [PlayDialogueCue:true]
        [DialogueCueId:AaW_Hunter_ApproachingPlayerTarget]

        [DisableTriggers:true]
        [DisableTriggerNames:AaW_Hunter_Trigger_ApproachingTarget_Player]
      </Description>
    </EntityComponent>

  </EntityComponents>
</Definitions>