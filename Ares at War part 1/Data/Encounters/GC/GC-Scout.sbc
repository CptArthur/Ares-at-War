<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
	<SpawnGroups>

		<SpawnGroup>
			<Id>
				<TypeId>SpawnGroupDefinition</TypeId> 
				<SubtypeId>GC_SpawnGroup_AtmosphericScout</SubtypeId>
			</Id>
			<Description>
			[Modular Encounters SpawnGroup]
		
			[FactionOverride:GC]

			[AtmosphericCargoShip:true]
			[UseCombatPhase:true]

			[PlanetWhitelist:Planet Agaris]	
			[SkipAirDensityCheck:false]
			[AtmosphericCargoShipChance:25]	

				
			[UseThreatLevelCheck:true]
			[ThreatLevelCheckRange:2000]
			[ThreatScoreGridConfiguration:Static]
			[ThreatScoreMinimum:500]	
			[ThreatIncludeOtherNpcOwners:true]
			[FactionOwner:GC]		

			[UseKnownPlayerLocations:true]
			[KnownPlayerLocationMustMatchFaction:true]
			[KnownPlayerLocationMustBeInside:false]			
		
			[UseRivalAi:true]
			[RivalAiReplaceRemoteControl:true]
			</Description>
			<Icon>Textures\GUI\Icons\Fake.dds</Icon>  
			<IsPirate>true</IsPirate>
			
			<Frequency>5.0</Frequency>
			<Prefabs>
		
				
				<Prefab SubtypeId="GC-Fighter-MK3">
					<Position>
						<X>0.0</X>
						<Y>0.0</Y>
						<Z>0.0</Z>
					</Position>
					<Speed>25</Speed>
					<Behaviour>GC_Scout_Behavior_Fighter</Behaviour>
				</Prefab>
			</Prefabs>			
		</SpawnGroup>










		


	</SpawnGroups>
</Definitions>