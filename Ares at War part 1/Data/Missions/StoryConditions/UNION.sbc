<!--UNIONNotYetLaunched-->
 	<EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>AZURIS_EventCondition_UNIONNotYetLaunched</SubtypeId>
      </Id>
      <Description>
     [MES Event Condition]
	  
	[UseAnyPassingCondition:false]

	[CheckFalseBooleans:true]
	[AllowAnyFalseBoolean:false]
	[FalseBooleans:UNION_Launched]  

	[CheckPlayerCondition:true]
	[PlayerConditionIds:PlayerCondition_AZURISFriendly]

      </Description>
    </EntityComponent>	


