<?xml version="1.0"?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <EntityComponents>
  
 <!--
 
 -->
 
    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>MILITIA_ContractBlockProfile_Civilian</SubtypeId>
      </Id>
      <Description>
        [MES Contract Block]

		[MissionIds:MILITIA_Mission_RelicData]
        
        [MinContracts:5]
        [MaxContracts:15]

								
      </Description>
    </EntityComponent>	

		<EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>MILITIA_Mission_RelicData</SubtypeId>
      </Id>
      <Description>

    [MES Mission]
	[Tags:SHIVAN]
	[OverrideFaction:SHIVAN]
	
	[Title:Sell Relic Data]
	[Description:]
	
	[StoreProfileId:AaW_StoreProfile_RelicData]
	[MissionType:Acquisition]
	
	[Reward:50000000]
	[Collateral:0]
	[ReputationReward:75]
	[FailReputationPrice:0]
	[Duration:5]


  [Exclusive:true]

      </Description>
    </EntityComponent>
	
	

 	<EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>MILITIA_EventCondition_MissionDestroyGCUraniumBase</SubtypeId>
      </Id>
      <Description>
     [MES Event Condition]
	  
	[UseAnyPassingCondition:false]

	[CheckFalseBooleans:true]
	[AllowAnyFalseBoolean:false]
	[FalseBooleans:GC_TechFacilityDestroyed]  

      </Description>
    </EntityComponent>	

   	<EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AaW_Mission_MILITIA_AttackGCTechFacility</SubtypeId>
      </Id>
      <Description>

    [MES Mission]
	
	[Title:Eliminate GC Uranium Base]
	[Description:They call it a base. We call it a pit of greed. Tear it down. Burn it out. No Corp stronghold can stand against the will of a free world. Your mission: destroy all GC positions at the uranium ore node. Expect heavy resistance.]
	
	[OverrideFaction:MILITIA]
	
	[Reward:25000000]
	[Collateral:50000]
	[ReputationReward:600]
	[FailReputationPrice:20]
	[Duration:0]

	[PersistantEventConditionIds:MILITIA_EventCondition_MissionDestroyGCUraniumBase]

	[ReplaceKeys:{StaticEncounterSandboxBoolName}]
	[ReplaceValues:GC_TechFacilityDestroyed]
	
	[ReplaceKeys:{EventName}]
	[ReplaceValues:Eliminate GC Tech Facility]	

	[ReplaceKeys:{EventCoords}]
	[ReplaceValues:{X:-3657092.61070023 Y:-1296007.60645679 Z:-2641605.119877}]	

		[Exclusive:true]
			
	[InstanceEventGroupId:MissionGroup_EliminateStaticEncounter]



      </Description>
    </EntityComponent> 




 	<EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>MILITIA_EventCondition_PersuadeAzuris</SubtypeId>
      </Id>
      <Description>
     [MES Event Condition]
	  
	[UseAnyPassingCondition:false]



	[CheckTrueBooleans:true]
	[TrueBooleans:GC_Martiallaw]  


	[CheckFalseBooleans:true]
	[AllowAnyFalseBoolean:false]
	[FalseBooleans:AzurisDestroyed]  
	[FalseBooleans:MILITIA_PersuadedAzuris]  	


	[CheckPlayerCondition:true]
	[PlayerConditionIds:PlayerCondition_AZURISFriendly]
	[PlayerConditionIds:PlayerCondition_MILITIAFriendly]

      </Description>
    </EntityComponent>	




   	<EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>AaW_Mission_MILITIA_PersuadeAzuris</SubtypeId>
      </Id>
      <Description>

    [MES Mission]
	
	[Title:(MILITIA) Persuade Azuris to Join the MILITIA]
	[Description:War with the corporations is inevitable. The colonies of Azuris, Bratis, and Thorrix must stand together under the banner of the MILITIA if they hope to defend themselves. With your support, we can begin gathering the weapons and supplies needed for the fight ahead. Once Azuris, Bratis, and Thorrix are convinced to commit, we will formally join the MILITIA and prepare for the conflict that's coming. REQUIRED FUNDS: 10m]
	
	[OverrideFaction:MILITIA]
	
	[Reward:0]
	[Collateral:10000000]
	[ReputationReward:500]
	[FailReputationPrice:0]
	[Duration:0]

	[PersistantEventConditionIds:MILITIA_EventCondition_PersuadeAzuris]

	[LeadPlayerConditionIds:PlayerCondition_AZURISFriendly]
	[LeadPlayerConditionIds:PlayerCondition_MILITIAFriendly]

	[InstanceEventGroupId:MissionGroup_ChatREPBooleanGPS]

	[ReplacePairs:{ChangeBooleans1},true]
	[ReplacePairs:{AddGPSToPlayers1},false]
	[ReplacePairs:{UseChatBroadcast1},false]
	[ReplacePairs:{ChangeReputationWithPlayers1},true]
	[ReplacePairs:{ChangeBooleans2},false]
	[ReplacePairs:{AddGPSToPlayers2},false]
	[ReplacePairs:{UseChatBroadcast2},true]
	[ReplacePairs:{ChangeReputationWithPlayers2},true]
	[ReplacePairs:{ChangeBooleans3},false]
	[ReplacePairs:{AddGPSToPlayers3},false]
	[ReplacePairs:{UseChatBroadcast3},false]
	[ReplacePairs:{ChangeReputationWithPlayers3},true]


	[ReplacePairs:{SetBooleansTrue1},MILITIA_PersuadedAzuris]
	[ReplacePairs:{ReputationChangeFaction1},Azuris]
	[ReplacePairs:{ReputationChangeAmount1},500]

	[ReplacePairs:{ChatOverrideAuthor2},MILITIA]
	[ReplacePairs:{ChatOverrideMessage2},Great Work {PlayerName}. Azuris joining our cause will greatly strengthen our efforts.]

	[ReplacePairs:{ReputationChangeFaction2},MILITIA]
	[ReplacePairs:{ReputationChangeAmount2},500]

	[ReplacePairs:{ReputationChangeFaction3},UNION]
	[ReplacePairs:{ReputationChangeAmount3},-100]



		[Exclusive:true]
			
      </Description>
    </EntityComponent> 











