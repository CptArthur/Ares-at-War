    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>AaW_EventTemplate_LaunchUNION_AZURISGPS</SubtypeId>
      </Id>
      <Description>

		[MES Event Template]
		[UseEvent:false]
		[UniqueEvent:true]	
		[MinCooldownMs:1000]
		[MaxCooldownMs:1001]	

    [PersistantConditionIds:AaW_EventConditionTemplate_LaunchUNION_AZURISNeutral]

		[ActionExecution:All]
		[TimeUntilNextActionMs:1100]
		
		[ActionIds:AaW_EventActionTemplate_LaunchUNION_AZURISGPS]

      </Description>      
	</EntityComponent>		
	
		<EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
          <TypeId>Inventory</TypeId>
          <SubtypeId>AaW_EventActionTemplate_LaunchUNION_AZURISGPS</SubtypeId>
      </Id>
      <Description>
	[MES Event Action Template]

	[AddGPSToPlayers:true]
	[AddGPSPlayerConditionIds:PlayerCondition_DummyTagCheck]
	[UseGPSObjective:false]
	
	[GPSNames:(UNION) Become friends with Azuris]
	[GPSVector3Ds:{X:-3684663 Y:-1332121 Z:-2634179}]

  [AddPlayerConditionPlayerTags:true]
  [AddIncludedPlayerTags:@{ContractId}]
	
      </Description>
    </EntityComponent>	


	
