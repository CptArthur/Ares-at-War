[CustomDataFiles:CIVILIAN_Land_Vehicles.xml]
[CustomDataFiles:CIVILIAN_Air_Vehicles.xml]
[CustomDataFiles:CIVILIAN_Space_Vehicles.xml]

[ApplyContractProfiles:true]
