    <EntityComponent xsi:type="MyObjectBuilder_InventoryComponentDefinition">
      <Id>
        <TypeId>Inventory</TypeId>
        <SubtypeId>CIVILIAN_Trigger_Static_PopulateStores_Azuris</SubtypeId>
      </Id>
      <Description>

[RivalAI Trigger]
[Tags:StoreRefresh]
[UseTrigger:true]
[Type:Timer]
[MinCooldownMs:1200000]
[MaxCooldownMs:1200001]
